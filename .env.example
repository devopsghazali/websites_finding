# .env.example — Copy karo → naam rakho .env → apni values daal do
# Google Maps API key zaroorat NAHI — free scraping mode use hoti hai

# ── EMAIL AUTO-SEND (REQUIRED for email feature) ─────────────────────────────
# Apna Gmail address
SENDER_EMAIL=sochghazali@gmail.com

# Gmail App Password (normal password NAHI, App Password chahiye)
# Steps:
#   1. myaccount.google.com → Security → 2-Step Verification ON karo
#   2. Security → App passwords → "Mail" select → Generate
#   3. 16-character code copy karo (spaces ke bina)
SENDER_APP_PASSWORD=abcd efgh ijkl mnop

# Aapka naam jo email mein dikhega
SENDER_NAME=Mohammad Hasnain

# Aapka phone (optional — email signature mein aayega)
SENDER_PHONE=+91 98765 43210

# Aapka portfolio/website (optional)
SENDER_PORTFOLIO=https://yourportfolio.com

# ── OPTIONAL (sirf AI message generation ke liye) ────────────────────────────
# Anthropic API Key — agar nahi hai toh template use hogi (FREE)
ANTHROPIC_API_KEY=
